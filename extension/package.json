{
  "name": "waillet",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node copy-icons.js && tsc && vite build && node build-extension-scripts.js",
    "build:firefox": "npm run build && node build-firefox.js",
    "build:all": "npm run build && node build-firefox.js",
    "dev:firefox": "npm run build:firefox && npx web-ext run --source-dir=./dist-firefox --firefox=firefox",
    "dev:firefox:nightly": "npm run build:firefox && npx web-ext run --source-dir=./dist-firefox --firefox=nightly",
    "lint:firefox": "npx web-ext lint --source-dir=./dist-firefox",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "npx playwright test --project=extension",
    "test:e2e:firefox": "npx playwright test --project=firefox",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:uniswap": "npx playwright test --project=uniswap",
    "test:e2e:uniswap:debug": "npx playwright test --project=uniswap --debug",
    "test:e2e:all": "npx playwright test",
    "setup-icons": "node copy-icons.js"
  },
  "dependencies": {
    "@mysten/sui": "^1.0.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^15.0.0",
    "buffer": "^6.0.3",
    "ethers": "^6.13.1",
    "hardhat": "^3.1.4",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.4.19",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.3.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^1.0.4",
    "web-ext": "^8.4.0"
  }
}
