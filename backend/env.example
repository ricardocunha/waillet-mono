# Database Configuration
DATABASE_URL=mysql+pymysql://waillet_user:waillet_pass@localhost:3306/waillet

# OpenAI API Key (for AI Agent intent parsing)
# Get free key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Origins (Chrome extension support)
# For development, use "*" to allow all origins
# For production, specify your extension ID: ["chrome-extension://YOUR_EXTENSION_ID"]
CORS_ORIGINS=["*"]

# RPC Provider API Keys (for blockchain connectivity)
# Backend RPC Proxy uses these to route blockchain requests

# Alchemy API Key (RECOMMENDED - supports Sepolia & Base Sepolia)
# Get free key: https://www.alchemy.com
# Sign up → Create App → Ethereum Sepolia → Copy API Key
# Free tier: 300M compute units/month
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Infura API Key (OPTIONAL - backup for Sepolia)
# Get free key: https://infura.io
# Sign up → Create New Key → Copy Project ID
# Free tier: 100k requests/day
# INFURA_API_KEY=your_infura_key_here
